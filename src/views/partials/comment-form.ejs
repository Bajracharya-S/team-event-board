<div id="comment-form">
  <form
    method="POST"
    action="/events/<%= eventId %>/comments"
    hx-post="/events/<%= eventId %>/comments"
    hx-target="#comment-list"
    hx-swap="outerHTML"
    class="m-0"
  >
    <div class="mb-3">
      <label for="comment-content" class="block text-sm font-medium text-slate-700 mb-1">
        Leave a comment
      </label>
      <textarea
        id="comment-content"
        name="content"
        rows="3"
        maxlength="500"
        placeholder="Ask a question or leave a note..."
        class="w-full px-3 py-2 rounded-xl border border-slate-200 bg-white text-sm text-slate-800 resize-none focus:outline-none focus:ring-2 focus:ring-blue-300"
      ></textarea>
      <p class="text-xs text-slate-400 mt-1 m-0">Max 500 characters.</p>
    </div>
    <button
      type="submit"
      class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium cursor-pointer hover:bg-blue-700"
    >
      Post Comment
    </button>
  </form>
</div>
