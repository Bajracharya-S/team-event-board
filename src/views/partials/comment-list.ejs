<div id="comment-list">
  <% if (comments.length === 0) { %>
    <p class="text-slate-400 text-sm text-center py-6 m-0">No comments yet. Be the first to comment.</p>
  <% } else { %>
    <ul class="space-y-3 list-none p-0 m-0">
      <% comments.forEach(function(comment) { %>
        <li class="p-4 border border-slate-100 rounded-xl bg-slate-50">
          <div class="flex items-start justify-between gap-2">
            <div class="flex-1">
              <p class="text-sm font-semibold text-slate-800 m-0 mb-1"><%= comment.authorDisplayName %></p>
              <p class="text-sm text-slate-700 m-0"><%= comment.content %></p>
              <p class="text-xs text-slate-400 m-0 mt-1">
                <%= new Date(comment.createdAt).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" }) %>
              </p>
            </div>
            <% if (currentUserId === comment.authorId || currentUserRole === "admin" || currentUserId === eventOrganizerId) { %>
              <form
                method="POST"
                action="/comments/<%= comment.id %>/delete"
                hx-post="/comments/<%= comment.id %>/delete"
                hx-target="#comment-list"
                hx-swap="outerHTML"
                class="m-0 shrink-0"
              >
                <input type="hidden" name="eventId" value="<%= comment.eventId %>" />
                <button
                  type="submit"
                  class="text-xs text-red-500 hover:text-red-700 bg-transparent border-0 cursor-pointer p-0 font-medium"
                >
                  Delete
                </button>
              </form>
            <% } %>
          </div>
        </li>
      <% }); %>
    </ul>
  <% } %>
</div>
