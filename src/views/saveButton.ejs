<div id="save-btn-<%= eventId %>">
  <form 
    hx-post="/events/<%= eventId %>/saveToggle"
    hx-target="#save-btn-<%= eventId %>"
    hx-swap="outerHTML"
  >
    <button 
      type="submit" 
      class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700 text-sm">
      
      <%= isSaved ? 'Unsave' : 'Save' %>
    </button>
  </form>
</div>