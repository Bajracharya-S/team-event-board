<h1><%= event.title %></h1>
<p><strong>Status:</strong> <%= event.status %></p>
<p><strong>Category:</strong> <%= event.category %></p>
<p><strong>Location:</strong> <%= event.location %></p>
<p><strong>Description:</strong> <%= event.description %></p>
<p><strong>Start:</strong> <%= event.startDatetime.toLocaleString() %></p>
<p><strong>End:</strong> <%= event.endDatetime.toLocaleString() %></p>
<p><strong>Organizer:</strong> <%= organizerName %></p>
<p><strong>Attending:</strong> 0 / <%= event.capacity ?? 'Unlimited' %></p>

<% if (currentUser.role === 'admin' || event.organizerId === currentUser.userId) { %>
  <% if (event.status === 'draft') { %>
    <form method="POST" action="/events/<%= event.id %>/publish">
      <button type="submit">Publish Event</button>
    </form>
  <% } %>
  <% if (event.status === 'published') { %>
    <form method="POST" action="/events/<%= event.id %>/cancel">
      <button type="submit">Cancel Event</button>
    </form>
  <% } %>
  <div id="attendee-list">
    <button
      hx-get="/events/<%= event.id %>/attendees/partial"
      hx-target="#attendee-list"
      hx-swap="outerHTML"
      class="px-4 py-2 rounded-lg bg-slate-600 text-white font-medium cursor-pointer hover:bg-slate-700 text-sm"
    >
      View Attendees
    </button>
  </div>
<% } else { %>
  <div class="flex gap-2">
  <button class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700 text-sm">RSVP</button>
  
  <% if (event.status === 'published') { %>
    <form method="POST" action="/events/<%= event.id %>/saveToggle">
      <button type="submit" class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700 text-sm">
        
        <%= savedEventIds.includes(event.id) ? 'Unsave' : 'Save' %>
      </button>
    </form>
    </div>
  </div>
<% } %>
<% } %>

<% if (pageError) { %>
  <p style="color: red;"><%= pageError %></p>
<% } %>