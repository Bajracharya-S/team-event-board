<div class="max-w-2xl mx-auto mt-10 px-4">
  <h1 class="text-2xl font-bold mb-6">Saved Events</h1>

  <% if (savedEvents.length === 0) { %>
    <p class="text-gray-500">You haven't saved any events yet.</p>
  <% } else { %>
    <ul class="space-y-4">
      <% savedEvents.forEach(event => { %>
        <li class="border rounded p-4">
          <p class="font-medium">Event #<%= event.eventId %></p>
          <p class="text-sm text-gray-500">Saved at <%= event.savedAt.toLocaleString() %></p>
          <form method="POST" action="/events/<%= event.eventId %>/saveToggle" class="mt-2">
            <button type="submit" class="text-sm text-red-500 hover:underline">
              Unsave
            </button>
          </form>
        </li>
      <% }) %>
    </ul>
  <% } %>
</div>