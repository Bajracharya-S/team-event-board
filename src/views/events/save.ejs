<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 mb-1">Saved Events</h1>
      <p class="text-slate-500 m-0">
        Showing saved events.
      </p>
    </div>
  </div>
</section>

<% if (savedEvents.length === 0) { %>
  <section class="p-10 border border-slate-200 rounded-2xl bg-white shadow-sm text-center">
    <p class="text-slate-400 text-lg m-0">You haven't saved any events yet.</p>
  </section>
<% } else { %>
  <ul class="space-y-3 list-none p-0 m-0">
    <% savedEvents.forEach(function(event) { %>
      <li class="p-5 border border-slate-200 rounded-2xl bg-white shadow-sm">
        <div class="flex items-start justify-between gap-3 flex-wrap">
          <div class="min-w-[240px]">
            <h2 class="text-lg font-semibold text-slate-900 mb-1">
              <a href="/events/<%= event.eventId %>" class="text-slate-900 no-underline hover:underline">Event #<%= event.eventId %></a>
            </h2>
            <p class="text-slate-500 text-sm m-0 mb-2">
              Saved at <%= event.savedAt.toLocaleString("en-US", { year: "numeric", month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" }) %>
            </p>
          </div>
          <div class="text-right shrink-0">
            <form 
              hx-post="/events/<%= event.eventId %>/saveToggle"
              hx-target="closest li"
              hx-swap="outerHTML"
            >
              <button type="submit" class="text-xs px-2.5 py-1 rounded-full bg-red-50 text-red-500 font-semibold hover:bg-red-100">
                Unsave
              </button>
            </form>
          </div>
        </div>
      </li>
    <% }) %>
  </ul>
<% } %>