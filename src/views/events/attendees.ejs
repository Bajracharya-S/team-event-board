<div class="max-w-2xl mx-auto mt-10 px-4">
  <h1 class="text-2xl font-bold mb-2">Attendees for Event #<%= eventId %></h1>
  <a href="/events/<%= eventId %>" class="text-blue-500 hover:underline text-sm">← Back to event</a>

  <% 
    const groups = [
      { label: 'Attending', key: 'going', color: 'green' },
      { label: 'Waitlisted', key: 'waitlisted', color: 'yellow' },
      { label: 'Cancelled', key: 'cancelled', color: 'red' },
    ]
  %>

  <% groups.forEach(group => { %>
    <div class="mt-8">
      <h2 class="text-lg font-semibold mb-3 text-<%= group.color %>-600">
        <%= group.label %> (<%= attendees[group.key].length %>)
      </h2>

      <% if (attendees[group.key].length === 0) { %>
        <p class="text-gray-400 text-sm">No one in this group.</p>
      <% } else { %>
        <ul class="space-y-2">
          <% attendees[group.key].forEach(entry => { %>
            <li class="border rounded p-3 flex justify-between items-center">
              <span class="font-medium"><%= entry.displayName %></span>
              <span class="text-sm text-gray-500">
                <%= entry.rsvpedAt.toLocaleString() %>
              </span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  <% }) %>
</div>