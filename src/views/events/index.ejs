<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 mb-1">Events</h1>
      <p class="text-slate-500 m-0">
        Showing <strong class="text-slate-700"><%= events.length %></strong> event<%= events.length === 1 ? '' : 's' %> you can access.
      </p>
    </div>
    <% if (currentUser.role === 'admin' || currentUser.role === 'staff') { %>
      <a href="/events/new" class="text-blue-700 font-semibold no-underline hover:underline text-sm">+ Create Event</a>
    <% } %>
  </div>
</section>

<% if (events.length === 0) { %>
  <section class="p-10 border border-slate-200 rounded-2xl bg-white shadow-sm text-center">
    <p class="text-slate-400 text-lg m-0">No events available.</p>
  </section>
<% } else { %>
  <ul class="space-y-3 list-none p-0 m-0">
    <% events.forEach(function(event) { %>
      <li class="p-5 border border-slate-200 rounded-2xl bg-white shadow-sm">
        <div class="flex items-start justify-between gap-3 flex-wrap">
          <div class="min-w-[240px]">
            <h2 class="text-lg font-semibold text-slate-900 mb-1">
              <a href="/events/<%= event.id %>" class="text-slate-900 no-underline hover:underline"><%= event.title %></a>
            </h2>
            <p class="text-slate-500 text-sm m-0 mb-2"><%= event.description %></p>
            <div class="flex items-center gap-3 flex-wrap">
              <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 font-medium">
                <%= event.category.charAt(0).toUpperCase() + event.category.slice(1) %>
              </span>
              <span class="text-xs text-slate-400"><%= event.location %></span>
              <% if (event.organizerId === currentUser.userId) { %>
                <span class="text-xs px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 font-semibold">Yours</span>
              <% } %>
            </div>
          </div>
          <div class="text-right shrink-0">
            <span class="text-xs px-2.5 py-1 rounded-full bg-slate-100 text-slate-500 font-semibold uppercase tracking-wide">
              <%= event.status %>
            </span>
            <p class="text-xs text-slate-400 mt-2 mb-0">
              <%= new Date(event.startDatetime).toLocaleString("en-US", { year: "numeric", month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" }) %>
              <span class="mx-1">&ndash;</span>
              <%= new Date(event.endDatetime).toLocaleString("en-US", { year: "numeric", month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" }) %>
            </p>
          </div>
        </div>
      </li>
    <% }) %>
  </ul>
<% } %>
