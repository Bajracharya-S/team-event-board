<div id="archive-results">
  <% if (events.length === 0) { %>
    <section class="p-10 border border-slate-200 rounded-2xl bg-white shadow-sm text-center">
      <p class="text-slate-400 text-lg m-0">
        <% if (selectedCategory) { %>
          No past events found in the <strong><%= selectedCategory %></strong> category.
        <% } else { %>
          No past events yet.
        <% } %>
      </p>
    </section>
  <% } else { %>
    <ul class="space-y-3 list-none p-0 m-0">
      <% events.forEach(function(event) { %>
        <li class="p-5 border border-slate-200 rounded-2xl bg-white shadow-sm opacity-80">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div>
              <h2 class="text-lg font-semibold text-slate-700 mb-1"><%= event.title %></h2>
              <p class="text-slate-500 text-sm m-0 mb-1"><%= event.description %></p>
              <div class="flex items-center gap-3 flex-wrap mt-2">
                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 font-medium">
                  <%= event.category.charAt(0).toUpperCase() + event.category.slice(1) %>
                </span>
                <span class="text-xs text-slate-400">
                  <%= event.location %>
                </span>
              </div>
            </div>
            <div class="text-right shrink-0">
              <span class="text-xs px-2.5 py-1 rounded-full bg-slate-100 text-slate-500 font-semibold uppercase tracking-wide">
                Past
              </span>
              <p class="text-xs text-slate-400 mt-1 mb-0">
                Ended <%= new Date(event.endDatetime).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }) %>
              </p>
            </div>
          </div>
        </li>
      <% }); %>
    </ul>
  <% } %>
</div>
